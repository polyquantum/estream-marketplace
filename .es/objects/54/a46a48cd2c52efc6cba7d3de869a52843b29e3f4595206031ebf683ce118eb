Å§Blobë≈w// Journey: Impact Stream Widget Lifecycle
// Tests the widget flow: authenticate ‚Üí validate metrics ‚Üí compute frame ‚Üí stream frame ‚Üí revoke

journey "impact_stream" {
    description "Widget lifecycle: authenticate, validate metrics, aggregate, stream, revoke"
    package "polyquantum.widgets"
    platform ">= 0.12.0"

    import widgets.circuits.impact_stream {
        authenticate_widget, validate_metric,
        compute_aggregate_frame, stream_impact_frame,
        revoke_widget_session,
        WidgetAuth, WidgetConfig, ImpactMetric, WidgetFrame
    }

    step "authenticate_widget_session" {
        let auth = WidgetAuth {
            widget_id: sha3_256("widget-carbon-01")[0:16],
            origin_hash: sha3_256("https://dashboard.example.com"),
            session_token: sha3_256("session-token-001"),
            expires_at: 1742086400000,
            scope: 1,
        }
        let authed = authenticate_widget(auth)
        assert authed == true
    }

    step "validate_carbon_metric" {
        let metric = ImpactMetric {
            metric_id: sha3_256("metric-co2-001")[0:16],
            metric_type: 1,
            value: 42000,
            unit_code: 1,
            timestamp: 1742000000,
        }
        let valid = validate_metric(metric)
        assert valid == true
    }

    step "validate_energy_metric" {
        let energy = ImpactMetric {
            metric_id: sha3_256("metric-energy-001")[0:16],
            metric_type: 2,
            value: 15000,
            unit_code: 2,
            timestamp: 1742000000,
        }
        let e_valid = validate_metric(energy)
        assert e_valid == true
    }

    step "stream_impact_frame" {
        let frame = WidgetFrame {
            widget_id: sha3_256("widget-carbon-01")[0:16],
            frame_seq: 1,
            metric_count: 2,
            total_carbon_grams: 42000,
            total_energy_wh: 15000,
            timestamp: 1742000100,
        }
        let streamed = stream_impact_frame(frame)
        assert streamed == true
    }

    step "revoke_session" {
        let revoked = revoke_widget_session(auth)
        assert revoked == true
    }
}
