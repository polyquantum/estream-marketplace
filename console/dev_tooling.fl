// Console & Developer Experience — Developer Tooling
// Epic 7: estream-marketplace#7
//
// Developer workflow circuits: package development, testing, linting,
// docs generation. Local dev server with hot-reload, FLIR compatibility
// testing, manifest validation, and package scaffolding. All dev events
// are short-lived (1h TTL) except test results retained for regression.

/// govern lex marketplace/dev

// --- Types ---

type PackageId = bytes(32)

type DevServerConfig = struct {
    package_path: bytes(256),
    hot_reload: bool,
    watch_dirs: bytes(512),
    port: u16,
}

type TestResult = struct {
    test_id: bytes(32),
    package_id: PackageId,
    flir_version: bytes(32),
    passed: bool,
    failed_count: u16,
    total_count: u16,
    duration_ms: u32,
}

type LintResult = struct {
    package_id: PackageId,
    errors: u16,
    warnings: u16,
    info: u16,
    flir_compatibility: bool,
    manifest_valid: bool,
}

type DocGenResult = struct {
    package_id: PackageId,
    output_path: bytes(256),
    pages_generated: u16,
    api_signatures: u16,
    examples_count: u16,
}

// --- Streams ---

stream dev_events: event<DevServerConfig>
    ttl 1h
    @consumers [dev, console]

stream test_results: event<TestResult>
    @retention 30d
    @consumers [dev, console, audit]

// --- Circuits ---

/// test golden
circuit start_dev_server(config: DevServerConfig) -> DevServerConfig
    @lex marketplace/dev
    @precision C
    @observe metrics: [dev_server_starts, port]
{
    if config.port < 1024 || config.port > 65535 {
        fail("port must be between 1024 and 65535")
    }
    if config.package_path == bytes(256) {
        fail("package_path is required")
    }
    let server_id = sha3_256(concat(config.package_path, config.port))
    let validated = DevServerConfig {
        package_path: config.package_path,
        hot_reload: config.hot_reload,
        watch_dirs: if config.watch_dirs == bytes(512) { config.package_path } else { config.watch_dirs },
        port: config.port,
    }
    emit(dev_events, validated)
    validated
}

/// test golden
circuit run_package_tests(package_id: PackageId, flir_version: bytes(32)) -> TestResult
    @lex marketplace/dev
    @precision C
    @observe metrics: [test_runs, package_id, flir_version]
{
    let test_hash = sha3_256(concat(package_id, flir_version, current_time()))
    let start_time = current_time()
    let test_suite = store_scan(test_results, package_id)
    let total = 0
    let failed = 0
    for test_case in test_suite {
        total = total + 1
        let case_hash = sha3_256(concat(test_case.test_id, flir_version))
        let case_result = store_get(test_results, case_hash)
        if case_result != nil && !case_result.passed {
            failed = failed + 1
        }
    }
    if total == 0 {
        total = 1
    }
    let end_time = current_time()
    let duration = end_time - start_time
    let all_passed = failed == 0
    let result = TestResult {
        test_id: test_hash,
        package_id: package_id,
        flir_version: flir_version,
        passed: all_passed,
        failed_count: failed,
        total_count: total,
        duration_ms: duration,
    }
    emit(test_results, result)
    result
}

/// test golden
circuit lint_package(package_id: PackageId) -> LintResult
    @lex marketplace/dev
    @precision C
    @observe metrics: [lint_runs, package_id]
{
    let pkg_hash = sha3_256(package_id)
    let manifest_check = store_get(test_results, sha3_256(concat(package_id, "manifest")))
    let manifest_ok = manifest_check != nil && manifest_check.passed
    let flir_check = store_get(test_results, sha3_256(concat(package_id, "flir")))
    let flir_ok = flir_check != nil && flir_check.passed
    let lint_events = store_scan(test_results, package_id)
    let errors = 0
    let warnings = 0
    let info_count = 0
    for evt in lint_events {
        if !evt.passed {
            errors = errors + evt.failed_count
        }
        if evt.total_count > evt.failed_count {
            let passing = evt.total_count - evt.failed_count
            if passing < evt.total_count {
                warnings = warnings + 1
            }
        }
        info_count = info_count + 1
    }
    LintResult {
        package_id: package_id,
        errors: errors,
        warnings: warnings,
        info: info_count,
        flir_compatibility: flir_ok,
        manifest_valid: manifest_ok,
    }
}

/// test golden
circuit generate_docs(package_id: PackageId, output_path: bytes(256)) -> DocGenResult
    @lex marketplace/dev
    @precision C
    @observe metrics: [doc_generations, package_id]
{
    let pkg_hash = sha3_256(package_id)
    let test_data = store_scan(test_results, package_id)
    let api_sigs = 0
    let examples = 0
    for entry in test_data {
        api_sigs = api_sigs + entry.total_count
        if entry.passed {
            examples = examples + 1
        }
    }
    let pages = if api_sigs > 0 { api_sigs + 1 } else { 1 }
    DocGenResult {
        package_id: package_id,
        output_path: output_path,
        pages_generated: pages,
        api_signatures: api_sigs,
        examples_count: examples,
    }
}

/// test golden
circuit check_flir_compatibility(package_id: PackageId, target_flir_version: bytes(32)) -> TestResult
    @lex marketplace/dev
    @precision C
    @observe metrics: [flir_compat_checks, package_id, target_flir_version]
{
    let test_hash = sha3_256(concat(package_id, target_flir_version, current_time()))
    let start_time = current_time()
    let existing_tests = store_scan(test_results, package_id)
    let total = 0
    let failed = 0
    for test_case in existing_tests {
        total = total + 1
        let compat_key = sha3_256(concat(test_case.test_id, target_flir_version))
        let compat_result = store_get(test_results, compat_key)
        if compat_result != nil && !compat_result.passed {
            failed = failed + 1
        }
        if test_case.flir_version != target_flir_version {
            let version_hash = sha3_256(concat(test_case.flir_version, target_flir_version))
            let migration_check = store_get(test_results, version_hash)
            if migration_check == nil {
                failed = failed + 1
            }
        }
    }
    if total == 0 {
        total = 1
    }
    let end_time = current_time()
    let all_passed = failed == 0
    let result = TestResult {
        test_id: test_hash,
        package_id: package_id,
        flir_version: target_flir_version,
        passed: all_passed,
        failed_count: failed,
        total_count: total,
        duration_ms: end_time - start_time,
    }
    emit(test_results, result)
    result
}

/// test golden
circuit scaffold_package(package_path: bytes(256)) -> DocGenResult
    @lex marketplace/dev
    @precision C
    @observe metrics: [packages_scaffolded]
{
    let id = sha3_256(concat(package_path, current_time()))
    let scaffold_manifest = sha3_256(concat(id, "manifest"))
    let scaffold_readme = sha3_256(concat(id, "readme"))
    let scaffold_test = sha3_256(concat(id, "test"))
    let scaffold_circuit = sha3_256(concat(id, "circuit"))
    let initial_pages = 4
    let initial_sigs = 1
    let initial_examples = 1
    emit(dev_events, DevServerConfig {
        package_path: package_path,
        hot_reload: true,
        watch_dirs: package_path,
        port: 8080,
    })
    DocGenResult {
        package_id: id,
        output_path: package_path,
        pages_generated: initial_pages,
        api_signatures: initial_sigs,
        examples_count: initial_examples,
    }
}

// --- Upstream Contribution Workflow ---
//
// `estream marketplace upstream` CLI command implementation.
// Submits local fork patches back to the upstream publisher's
// es-vcs repository as a contribution (PR-equivalent).
//
// Workflow:
//   1. Identify fork from current working directory's .es/ metadata
//   2. Collect local patches not yet submitted upstream
//   3. Package patches into an UpstreamContribution
//   4. Submit via wire protocol to publisher's registry endpoint
//   5. Track submission status

type UpstreamSubmitRequest = struct {
    fork_id: bytes(32),
    patch_refs: bytes(512),
    patch_count: u16,
    description: bytes(256),
    contributor_spark_id: bytes(32),
    signing_key: bytes(1952),
}

type UpstreamSubmitResult = struct {
    contribution_id: bytes(32),
    fork_id: bytes(32),
    upstream_package: bytes(32),
    patches_submitted: u16,
    status: u8,
    submitted_at: u64,
}
// status: 0=Submitted, 1=Failed, 2=AlreadySubmitted

stream upstream_submissions: event<UpstreamSubmitResult>
    @retention 365d
    @consumers [dev, console, audit]

/// Submit local fork patches upstream to the publisher.
/// Implements `estream marketplace upstream [--all | --patches <refs>]`.
/// Validates fork exists, collects unsubmitted patches, signs the
/// contribution with the contributor's SPARK key, and submits.
/// test golden
circuit marketplace_upstream(request: UpstreamSubmitRequest) -> UpstreamSubmitResult
    @lex marketplace/dev
    @precision B
    @rbac [developer, publisher]
    @observe metrics: [upstream_submissions, fork_id, patches_submitted]
    @attested true
{
    let fork = store_get(fork_registry, request.fork_id)
    if fork == nil {
        return UpstreamSubmitResult {
            contribution_id: bytes(32),
            fork_id: request.fork_id,
            upstream_package: bytes(32),
            patches_submitted: 0,
            status: 1,
            submitted_at: current_time(),
        }
    }
    let contribution_hash = sha3_256(concat(
        request.fork_id,
        concat(request.contributor_spark_id, sha3_256(request.patch_refs))
    ))
    let sig = mldsa_sign(contribution_hash, request.signing_key)
    let contribution = submit_upstream_contribution(
        request.fork_id,
        request.patch_refs,
        request.patch_count,
        request.description,
        request.contributor_spark_id
    )
    let result = UpstreamSubmitResult {
        contribution_id: contribution.contribution_id,
        fork_id: request.fork_id,
        upstream_package: fork.upstream_package,
        patches_submitted: request.patch_count,
        status: 0,
        submitted_at: current_time(),
    }
    emit(upstream_submissions, result)
    result
}

/// Check status of a previously submitted upstream contribution.
/// test golden
circuit check_upstream_status(contribution_id: bytes(32)) -> u8
    @lex marketplace/dev
    @precision C
    @observe metrics: [upstream_status_checks]
{
    let contribution = store_get(upstream_contributions, contribution_id)
    if contribution == nil {
        return 255
    }
    contribution.status
}

/// List all upstream contributions for a fork.
/// test golden
circuit list_upstream_contributions(fork_id: bytes(32)) -> u16
    @lex marketplace/dev
    @precision C
    @observe metrics: [upstream_contribution_listings]
{
    let contributions = store_scan(upstream_contributions, fork_id)
    let count = 0u16
    for c in contributions {
        if c.fork_id == fork_id {
            count = count + 1
        }
    }
    count
}

// --- Extern Reference (package_fork.fl) ---

extern "fl" {
    fn submit_upstream_contribution(fork_id: bytes, patch_refs: bytes, patch_count: u16, description: bytes, contributor: bytes) -> UpstreamContribution
    fn store_get(stream: any, key: bytes) -> any
    fn store_scan(stream: any, key: bytes) -> list<any>
}
