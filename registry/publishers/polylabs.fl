/// Publisher registration: Poly Labs
/// Registers all 38 Poly products in the marketplace.
/// Epic: polylabs-dev/polylabs#25, estream-marketplace#19

/// govern lex marketplace/registry

circuit register_polylabs_publisher() -> bool
    @lex marketplace/registry
    @precision A
    @attested true
    @observe metrics: [publisher_registrations]
{
    let publisher = register_publisher(
        "polylabs",
        "Poly Labs",
        "engineering@polylabs.dev",
        "https://polylabs.dev",
        "https://github.com/polylabs-dev"
    )

    register_polylabs_platform(publisher)
    register_polylabs_productivity(publisher)
    register_polylabs_communication(publisher)
    register_polylabs_security(publisher)
    register_polylabs_developer(publisher)
    register_polylabs_enterprise(publisher)
    register_polylabs_consumer(publisher)
    register_polylabs_data_rooms(publisher)
    register_polylabs_hardware(publisher)
}

/// Category 90: Platform
circuit register_polylabs_platform(publisher_id: bytes(32)) -> bool
    @lex marketplace/registry
    @precision A
{
    register_package(publisher_id, "polykit", "0.22.0", "smart-circuit",
        "Shared composition framework: identity, metering, telemetry, rate-limiting, sanitization, zero-linkage, governance, blind-telemetry, portal context",
        ["framework", "composition", "identity", "metering", "pq-crypto"],
        "0.22.0",
        [],
        ["derive_keys", "record_usage", "emit_gauge", "check_rate", "sanitize", "classify_content"]
    )

    register_package(publisher_id, "polylabs-console", "0.22.0", "console-widget",
        "Unified admin console for all Poly products: widget registry, RBAC, event bus",
        ["console", "admin", "rbac", "widgets"],
        "0.22.0",
        ["polykit"],
        ["check_access", "process_widgets", "emit_widget_event"]
    )

    true
}

