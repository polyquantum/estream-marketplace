        BundledPackage { package_id: resolve("polylabs", "polycalendar"), version: "0.1.0", required: false },
        BundledPackage { package_id: resolve("polylabs", "polytasks"), version: "0.1.0", required: false },
        BundledPackage { package_id: resolve("polylabs", "polyforms"), version: "0.1.0", required: false },

        BundledPackage { package_id: resolve("polylabs", "polymessenger"), version: "0.12.0", required: false },
        BundledPackage { package_id: resolve("polylabs", "polymail"), version: "0.1.0", required: false },
        BundledPackage { package_id: resolve("polylabs", "polyphone"), version: "0.1.0", required: false },

        BundledPackage { package_id: resolve("polylabs", "polypass"), version: "0.12.0", required: false },
        BundledPackage { package_id: resolve("polylabs", "polyoauth"), version: "0.1.0", required: false },
        BundledPackage { package_id: resolve("polylabs", "polyvpn"), version: "0.1.0", required: false },
        BundledPackage { package_id: resolve("polylabs", "polyauthenticator"), version: "0.1.0", required: false },

