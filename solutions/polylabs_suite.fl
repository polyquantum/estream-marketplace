circuit polylabs_suite_lex_policy() -> LexPolicy
    @lex marketplace/solutions
{
    LexPolicy {
        hierarchy: "esn/global/org/polylabs/suite",
        isolation: "PRIME-attested",
        rbac_template: "polylabs-default",
        data_residency: "customer-choice",
        retention_default: "365d",
        zero_linkage: true,
    }
}

circuit polylabs_suite_branding() -> SolutionBranding
    @lex marketplace/solutions
{
    SolutionBranding {
        display_name: "Poly Labs Suite",
        theme_hash: hash("polylabs-default-theme-v1"),
        logo_hash: hash("polylabs-logo-v1"),
        documentation_url: "https://docs.polylabs.dev/suite",
    }
}

/// Vertical-specific sub-bundles for selective installation
circuit register_polylabs_productivity_bundle() -> SolutionId
    @lex marketplace/solutions
    @precision A
    @attested true
{
    let manifest = SolutionManifest {
        solution_id: derive_solution_id("polylabs-productivity", "0.22.0"),
        name: "polylabs-productivity",
        version: "0.22.0",
        publisher: "polylabs",
        description: "Poly Labs Productivity Suite: Docs, Slides, Sheets, Notes, Calendar, Tasks, Forms",
        packages_count: 9,
        lex_policy_hash: hash_lex_policy(polylabs_suite_lex_policy()),
        branding_hash: hash_branding(polylabs_suite_branding()),
        pricing_model: 0,
        tier: 1,
        created_at: now(),
    }

    let packages = [
        BundledPackage { package_id: resolve("polylabs", "polykit"), version: "0.22.0", required: true },
        BundledPackage { package_id: resolve("polylabs", "polylabs-console"), version: "0.22.0", required: true },
        BundledPackage { package_id: resolve("polylabs", "polydocs"), version: "0.1.0", required: false },
        BundledPackage { package_id: resolve("polylabs", "polyslides"), version: "0.1.0", required: false },
        BundledPackage { package_id: resolve("polylabs", "polysheets"), version: "0.1.0", required: false },
        BundledPackage { package_id: resolve("polylabs", "polynotes"), version: "0.1.0", required: false },
        BundledPackage { package_id: resolve("polylabs", "polycalendar"), version: "0.1.0", required: false },
        BundledPackage { package_id: resolve("polylabs", "polytasks"), version: "0.1.0", required: false },
        BundledPackage { package_id: resolve("polylabs", "polyforms"), version: "0.1.0", required: false },
    ]

    register_solution(manifest, packages)
    manifest.solution_id
}

