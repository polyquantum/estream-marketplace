/// Poly Labs Suite — Solution Bundle for Third-Party Consumption
/// Defines the complete Poly Labs product suite as a marketplace solution
/// bundle that TakeTitle (and other platform consumers) can install.
///
/// Epic: estream-marketplace#19, polylabs-dev/polylabs#25

/// govern lex marketplace/solutions

circuit register_polylabs_suite() -> SolutionId
    @lex marketplace/solutions
    @precision A
    @attested true
    @observe metrics: [solution_registrations]
{
    let manifest = SolutionManifest {
        solution_id: derive_solution_id("polylabs-suite", "0.22.0"),
        name: "polylabs-suite",
        version: "0.22.0",
        publisher: "polylabs",
        description: "Complete Poly Labs platform: 38 products across 8 verticals — productivity, communication, security, developer, enterprise, consumer, data rooms, hardware-enhanced",
        packages_count: 38,
        lex_policy_hash: hash_lex_policy(polylabs_suite_lex_policy()),
        branding_hash: hash_branding(polylabs_suite_branding()),
        pricing_model: 0,
        tier: 1,
        created_at: now(),
    }

    let packages = polylabs_suite_packages()
    register_solution(manifest, packages)

    manifest.solution_id
}

circuit polylabs_suite_packages() -> list<BundledPackage>
    @lex marketplace/solutions
{
    [
        BundledPackage { package_id: resolve("polylabs", "polykit"), version: "0.22.0", required: true },
        BundledPackage { package_id: resolve("polylabs", "polylabs-console"), version: "0.22.0", required: true },

        BundledPackage { package_id: resolve("polylabs", "polydocs"), version: "0.1.0", required: false },
        BundledPackage { package_id: resolve("polylabs", "polyslides"), version: "0.1.0", required: false },
        BundledPackage { package_id: resolve("polylabs", "polysheets"), version: "0.1.0", required: false },
