        BundledPackage { package_id: resolve("polylabs", "polystudio"), version: "0.1.0", required: false },
        BundledPackage { package_id: resolve("polylabs", "polyregistry"), version: "0.1.0", required: false },
        BundledPackage { package_id: resolve("polylabs", "polymonitor"), version: "0.1.0", required: false },

        BundledPackage { package_id: resolve("polylabs", "polycomply"), version: "0.1.0", required: false },
        BundledPackage { package_id: resolve("polylabs", "polysign"), version: "0.1.0", required: false },
