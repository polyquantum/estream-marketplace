/// Marketplace Inventory — Platform Graph population data for the eStream Marketplace.
/// Registers all marketplace verticals, their sub-components, and circuit counts.
/// govern lex marketplace/inventory
///
/// 13 verticals, 113 circuits total across marketplace domain modules.
///
/// Epic: polyquantum/estream#136

// ── Shared Types ─────────────────────────────────────────────────

type VerticalName = bytes(64)
type SubComponentName = bytes(64)

type VerticalInfo = struct {
    name: VerticalName,
    circuit_count: u32,
    sub_component_count: u32,
    description: bytes(256),
    since_version: bytes(20),
}

type SubComponentInfo = struct {
    name: SubComponentName,
    vertical: VerticalName,
    circuit_count: u32,
}

type MarketplacePopulationSummary = struct {
    verticals_registered: u32,
    total_circuits: u32,
    sub_components_registered: u32,
}

// ── Marketplace Inventory Graph ──────────────────────────────────

graph marketplace_inventory {
    node VerticalInfo
    edge struct { registered_at: u64 }

    overlay circuit_count: u32 bitmask delta_curate
    overlay sub_component_count: u32 bitmask delta_curate
    overlay health_score: u16 curate delta_curate

    storage csr {
        hot @bram,
        warm @ddr,
        cold @nvme,
    }

    ai_feed marketplace_catalog_health

    @observe marketplace_inventory: [circuit_count, sub_component_count, health_score] threshold: {
        anomaly_score 0.85
        baseline_window 300
    }
}

series inventory_series: marketplace_inventory
    @merkle_chain true
    @lattice_imprint true
    @witness_attest true

// ── Vertical Registration Circuits ───────────────────────────────
//
// Each circuit registers a marketplace vertical and returns its circuit count.
// Verticals are organized by domain; sub-component breakdowns are documented
// in comments and enforced by golden tests.

// ── Advertising (24 circuits, 10 sub-components) ─────────────────
//
//   etch (ad creative rendering), catalyst (campaign optimization),
//   crm (advertiser relationship), optin (consent management),
//   portal (self-serve dashboard), relay (ad delivery network),
//   sage (predictive analytics), scope (audience targeting),
//   thread (conversation ads), tide (real-time bidding)

/// Register the advertising vertical — 24 circuits across 10 sub-components.
circuit register_advertising(graph_id: bytes(32)) -> u32
    lex marketplace/inventory
    @status production
    @precision B
    observe metrics: [vertical_circuit_count, sub_component_count]
    test golden "advertising_circuits" {
        let count = register_advertising(bytes(32))
        assert count == 24
    }
{
    // etch: 3, catalyst: 3, crm: 2, optin: 2, portal: 3,
    // relay: 2, sage: 3, scope: 2, thread: 2, tide: 2
    24
}

