// ── Full Population ──────────────────────────────────────────────

/// Run all vertical registration circuits to populate the marketplace inventory.
/// Returns the total circuit count across all 13 verticals (113 circuits).
circuit populate_marketplace_inventory(graph_id: bytes(32)) -> u32
    lex marketplace/inventory
    @status production
    @precision B
    @attested true
    observe metrics: [total_circuit_count, verticals_registered]
    test golden "populate_all" {
        let total = populate_marketplace_inventory(bytes(32))
        assert total == 113
    }
{
    let advertising  = register_advertising(graph_id)   // 24
    let bridge       = register_bridge(graph_id)        //  9
    let console      = register_console(graph_id)       //  5
    let fintech      = register_fintech(graph_id)       //  7
    let industrial   = register_industrial(graph_id)    // 19
    let licensing    = register_licensing(graph_id)      //  4
    let payments     = register_payments(graph_id)      // 14
    let pricing      = register_pricing(graph_id)       //  1
    let radio        = register_radio(graph_id)         //  7
    let registry     = register_registry(graph_id)      //  4
    let secure_video = register_secure_video(graph_id)  // 12
    let solutions    = register_solutions(graph_id)     //  5
    let widgets      = register_widgets(graph_id)       //  2
    // ────────────────────────────────────────────────── = 113
    advertising + bridge + console + fintech + industrial + licensing
        + payments + pricing + radio + registry + secure_video
        + solutions + widgets
}
